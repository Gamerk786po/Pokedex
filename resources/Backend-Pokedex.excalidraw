      "isDeleted": false,
      "boundElements": [],
      "updated": 1784003596393,
      "link": null,
      "locked": true,
      "text": "Endpoint:/api/v1/getData\n1-Frontend send get request.\n2-Auth (middleware) access tokens\nand attach the id with the request.\n3-Server gets the id from request\n4-Server fetch the data from database\n5-Send the resp back to frontend",
      "fontSize": 52.57142857142856,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Endpoint:/api/v1/getData\n1-Frontend send get request.\n2-Auth (middleware) access tokens\nand attach the id with the request.\n3-Server gets the id from request\n4-Server fetch the data from database\n5-Send the resp back to frontend",
      "autoResize": true,
      "lineHeight": 1.25
    },
